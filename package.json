    "@octokit/webhooks": "^13.4.2",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.5",
    "openai": "^4.85.0",
    "pino": "^9.6.0",
    "smee-client": "^2.0.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
