# ── GitHub App ────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# ── Claude API Key ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Allowed repos (comma-separated, leave empty to allow all) ──
# ALLOWED_REPOS=myorg/repo1,myorg/repo2

# ── Server ───────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── Dev (optional) ───────────────────────────────────
# SMEE_URL=https://smee.io/your-channel
